{
  "name": "setu",
  "version": "1.0.0",
  "description": "Setu - NexInvo Tally Connector",
  "main": "src/main/main.js",
  "author": "NexInvo",
  "license": "MIT",
  "scripts": {
    "start": "node start.js",
    "dev": "node start.js",
    "build": "electron-builder",
    "build:win": "electron-builder --win",
    "pack": "electron-builder --dir",
    "postinstall": "electron-builder install-app-deps"
  },
  "build": {
    "appId": "com.nexinvo.setu",
    "productName": "Setu",
    "copyright": "Copyright © 2026 Chinmay Technosoft Private Limited",
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "files": [
      "src/**/*",
      "assets/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.png",
      "publisherName": "Chinmay Technosoft Private Limited",
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Setu - NexInvo Tally Connector"
    }
  },
  "dependencies": {
    "axios": "^1.6.0",
    "electron-store": "^8.1.0",
    "ws": "^8.14.0",
    "xml2js": "^0.6.2"
  },
  "devDependencies": {
    "cross-env": "^7.0.3",
    "electron": "^33.0.0",
    "electron-builder": "^24.9.0",
    "sharp": "^0.34.5"
  }
}
